SCHEDULER_ENV=development
SCHEDULER_LISTEN_ADDR=:8080
# Option 1: provide a full DSN URL
SCHEDULER_DATABASE_URL=postgres://scheduler:scheduler@localhost:5432/scheduler?sslmode=disable
# Option 2: provide discrete fields (used when SCHEDULER_DATABASE_URL is empty)
SCHEDULER_DB_USER=scheduler
SCHEDULER_DB_PASSWORD=scheduler
SCHEDULER_DB_HOST=localhost
SCHEDULER_DB_PORT=5432
SCHEDULER_DB_NAME=scheduler
SCHEDULER_DB_SSLMODE=disable
SCHEDULER_SESSION_SECRET=change_me_to_32_plus_characters_long_secret
JB2_CLIENT_ID=your-client-id
JB2_CLIENT_SECRET=your-client-secret
JB2_BASE_URL=https://api-jb2.integrations.ecimanufacturing.com
JB2_TOKEN_URL=https://api-user.integrations.ecimanufacturing.com/oauth2/api-user/token
